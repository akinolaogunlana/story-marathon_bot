name: 🌐 StoryMinta Cloud Bot
on:
  schedule:
    - cron: '*/30 * * * *'  # Every 30min
  workflow_dispatch:  # Manual trigger
  push:
    paths: ['**']

jobs:
  marathon:
    runs-on: ubuntu-latest
    timeout-minutes: 360  # 6hr max per run
    steps:
    - uses: actions/checkout@v4
    
    - name: Setup Python
      uses: actions/setup-python@v5
      with:
        python-version: '3.11'
    
    - name: Install deps
      run: pip install requests psutil selenium webdriver-manager
    
    - name: 🕐 StoryMinta 3:30 Marathon
      run: |
        python cloud_bot.py
        
    - name: 📊 Upload Stats
      uses: actions/upload-artifact@v4
      with:
        name: storyminta-stats
        path: stats/
        
    - name: 💾 Save Progress
      run: |
        echo "::notice:: Bot completed $(cat stats/progress.txt || echo 0) stories!"
